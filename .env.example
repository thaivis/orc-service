API_KEY=change-me-to-a-long-random-string
PORT=8000
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_DIMENSION=2000
LOG_LEVEL=info

# AES-256-GCM encryption key — 64 hex characters (32 bytes)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-me-to-64-hex-chars

# Hotel name stamped into the watermark overlay
HOTEL_NAME=Hotel

# Public base URL for /document/{key} links in scan responses (leave empty for relative paths)
PUBLIC_BASE_URL=

# MinIO object storage — leave MINIO_ENDPOINT unset to disable image storage
# Local dev (uvicorn directly): use localhost:9000
# docker compose: endpoint is overridden to minio:9000 in docker-compose.yml
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=thaivis-id-documents
MINIO_USE_SSL=false
# NOTE: 90-day auto-delete lifecycle rule is NOT configured by application code.
# After running `docker compose up`, set it manually via:
#   MinIO Console → http://localhost:9001 → Buckets → thaivis-id-documents → Lifecycle
# or via mc CLI:
#   mc ilm add --expiry-days 90 local/thaivis-id-documents
